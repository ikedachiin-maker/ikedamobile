# ─────────────────────────────────────────────
# jpmob ログイン情報
# ─────────────────────────────────────────────
JPMOB_USERNAME=your_email@gmail.com
JPMOB_PASSWORD=your_password

# ─────────────────────────────────────────────
# Google スプレッドシートの設定
# ─────────────────────────────────────────────
# Googleフォームの回答が溜まるスプレッドシートID
SPREADSHEET_ID=your_spreadsheet_id
SHEET_NAME=フォームの回答 1

# 割り当て管理スプレッドシートID（初回実行後に自動生成されます）
ASSIGNMENT_SPREADSHEET_ID=

# ─────────────────────────────────────────────
# Gmail 送信設定
# ─────────────────────────────────────────────
GMAIL_SENDER=your_email@gmail.com
GMAIL_SUBJECT=【ikedamobile】SIM情報のご連絡
GMAIL_EMAIL_COLUMN=メールアドレス

# 性別のデフォルト値（male / female）
JPMOB_DEFAULT_SEX=male

# ─────────────────────────────────────────────
# 動作設定
# ─────────────────────────────────────────────
# jpmob入力後の待機時間（秒）デフォルト3600秒 = 60分
SEND_DELAY_SECONDS=3600

# ─────────────────────────────────────────────
# 処理済み管理
# ─────────────────────────────────────────────
STATUS_COLUMN=予約番号案内

# ─────────────────────────────────────────────
# Stripe 設定
# ─────────────────────────────────────────────
# Stripe シークレットキー（Stripe Dashboard > 開発者 > APIキー）
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# フォーム記入リマインダー設定
# ─────────────────────────────────────────────
# 登録フォームのURL（Googleフォームの共有URL）
GOOGLE_FORM_URL=https://forms.gle/xxxxxxxx
# 1回目リマインダーを送るまでの時間（時間）
REMINDER_HOURS_1=24
# 2回目リマインダーを送るまでの時間（時間）
REMINDER_HOURS_2=48
